# Version control
.git
.gitignore

# Python caches and build artefacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
dist/
build/
.eggs/

# Virtual environments
.venv
venv
env

# Test / lint caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
coverage.xml
htmlcov/

# Tests (not needed in the production image)
server/tests/

# IDE and editor files
.idea
.vscode
*.swp
*.swo

# Project documentation and notebooks (not needed at runtime)
.docs/
.notebooks/
*.md
ONNX_INTEGRATION_SUMMARY.md

# Windows helper scripts
*.ps1

# HTTP test files
test_api.http

# Docker files themselves (avoid recursive context)
Dockerfile
docker-compose.yml
.dockerignore

# Environment files (secrets must never be baked into the image)
.env
.env.*
!.env.example

# Top-level models/ directory (training artefacts — served via volume mount)
models/

# GitHub Actions (not needed in the image)
.github/
.claude/
