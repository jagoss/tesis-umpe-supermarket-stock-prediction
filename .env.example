# .env.example — copy to .env and fill in your values before running docker compose
#
# IMPORTANT: Never commit .env to version control.
# This file is safe to commit — it contains no real secrets.

# =============================================================================
# Prediction Server
# =============================================================================

# Backend to use: "onnx" (default, requires a model file) or "dummy" (for testing)
MODEL_BACKEND=onnx

# Path to the ONNX model artefact inside the container.
# With docker-compose this is relative to /app (WORKDIR).
# The volume mount in docker-compose maps MODEL_ARTIFACTS_PATH on the host
# to /app/server/models in the container, so only the filename matters here.
MODEL_PATH=server/models/example_model.onnx

# Constant value returned by the dummy backend (only used when MODEL_BACKEND=dummy)
DEFAULT_PREDICTION_VALUE=0

# Host path to the directory containing model artefacts.
# Mounted read-only into the container so swapping a production model only
# requires replacing the file on the host and restarting the service.
# Default: ./server/models (the example model included in the repository)
MODEL_ARTIFACTS_PATH=./server/models

# =============================================================================
# PostgreSQL (used by Onyx)
# =============================================================================

POSTGRES_USER=onyx
# Change this to a strong password in production
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=onyx

# =============================================================================
# Onyx — LLM Configuration
# =============================================================================

# LLM provider: openai | anthropic | azure | ollama | ...
# See https://docs.onyx.app/gen_ai_configs/overview for all supported providers
GEN_AI_MODEL_PROVIDER=openai

# Model version to use for chat / agent tasks
GEN_AI_MODEL_VERSION=gpt-4o-mini

# API key for the LLM provider (OpenAI, Anthropic, etc.)
# Leave empty if using a local LLM (Ollama)
GEN_AI_API_KEY=your_llm_api_key_here

# =============================================================================
# Onyx — Security
# =============================================================================

# Random secret used to encrypt sensitive data at rest.
# Generate a new value with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY_SECRET=change_me_in_production

# Authentication mode:
#   disabled    — no login required (development / local use only)
#   basic       — username + password
#   google_oauth — Google OAuth2
# See https://docs.onyx.app/configuration_guide
AUTH_TYPE=disabled

# =============================================================================
# Onyx — Version & Telemetry
# =============================================================================

# Pin to a specific Onyx release tag (e.g. v0.20.0) or leave as "latest"
ONYX_VERSION=latest

# Set to "true" to disable anonymous usage statistics sent to Onyx
DISABLE_TELEMETRY=true

# =============================================================================
# Onyx — Web Frontend
# =============================================================================

# Public URL where the Onyx UI is accessible.
# Update this when deploying behind a reverse proxy or to a cloud VM.
WEB_DOMAIN=http://localhost:3000

# =============================================================================
# Onyx — Embedding / Reranking Model Server
# =============================================================================

# Minimum number of threads for ML model serving
MIN_THREADS_ML_MODELS=1
